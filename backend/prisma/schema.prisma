// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id               String            @id @default(cuid())
  patientName      String
  patientEmail     String
  patientPhone     String
  date             String
  time             String
  doctorName       String?
  speciality       String?
  symptoms         String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}
